generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Household {
  id        String   @id @default(cuid())
  name      String   @default("My Household")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  accounts     Account[]
  transactions Transaction[]
  budgets            Budget[]
  goals              Goal[]
  sharingPreferences SharingPreference[]
  invites            HouseholdInvite[]
}

model User {
  id          String   @id @default(cuid())
  clerkId     String   @unique
  email       String   @unique
  firstName   String?
  lastName    String?
  imageUrl    String?
  role        String   @default("owner") // owner | member
  householdId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  household    Household?    @relation(fields: [householdId], references: [id])
  plaidItems   PlaidItem[]
  snapTradeItems     SnapTradeItem[]
  accounts     Account[]
  transactions       Transaction[]
  goals              Goal[]
  sharingPreferences SharingPreference[]
  sentInvites        HouseholdInvite[]
}

model PlaidItem {
  id                  String   @id @default(cuid())
  plaidItemId         String   @unique
  accessTokenEncrypted String  // encrypted access token
  institutionId       String?
  institutionName     String?
  cursor              String?  // for transaction sync pagination
  lastSyncedAt        DateTime?
  userId              String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accounts Account[]
}

model Account {
  id              String   @id @default(cuid())
  plaidAccountId  String   @unique
  name            String
  officialName    String?
  // Built-in types: depository, credit, loan, investment.
  // Manual asset types: real_estate, vehicle, other_asset.
  // Manual liability type: loan (provider="manual" + merchantPatterns for
  // auto-amortization).
  type            String
  subtype         String?  // checking, savings, credit card, primary residence, etc.
  mask            String?  // last 4 digits, or VIN tail for vehicles
  currentBalance  Float?
  availableBalance Float?
  isoCurrencyCode String?  @default("USD")
  // Manual-asset fields (provider="manual"). Optional for aggregator
  // accounts. purchasePrice is the original cost basis (or original
  // loan principal); purchaseDate lets us show holding period and
  // anchors loan amortization.
  purchasePrice   Float?
  purchaseDate    DateTime?
  notes           String?
  // Manual loans only: annual interest rate as a percentage (e.g. 6.5
  // for 6.5% APR / note rate). Drives the amortization schedule. For
  // loans with rate buydowns, this is always the underlying note rate;
  // the buydown only affects the payment amount, not amortization.
  interestRate    Float?
  // Manual loans only: total months in the loan term (60 = 5yr car,
  // 360 = 30yr mortgage). Used by the amortization engine to compute
  // scheduled principal/interest per month.
  termMonths      Int?
  // Manual loans only: scheduled monthly P&I payment. If null, derived
  // from principal + rate + term. User can override (e.g. if the
  // lender uses a slightly different rounding).
  monthlyPayment  Float?
  // Manual loans only: monthly escrow component (property tax +
  // homeowners insurance held by the lender). Subtracted from bank
  // payments before applying anything to principal — escrow does NOT
  // reduce the loan balance.
  escrowMonthly   Float?
  // Manual loans only: monthly HOA fee, if the lender collects it.
  // Also excluded from principal reduction.
  hoaMonthly      Float?
  // Manual loans only: planned recurring extra principal payment above
  // scheduled P&I. Accelerates payoff.
  extraPrincipalMonthly Float?
  // Manual loans only: actual outstanding balance as of `currentBalanceAsOf`,
  // as reported by the lender. When set, this anchors the amortization
  // engine — balance is rolled forward from this anchor using the loan's
  // scheduled monthly payment and rate. Lets users skip having to get
  // start date / original principal exactly right.
  currentBalanceOverride Float?
  // Manual loans only: the date the user observed `currentBalanceOverride`.
  // Defaults to "now" when override is set without an explicit date.
  currentBalanceAsOf     DateTime?
  // Manual loans only: case-insensitive substring patterns matched
  // against Transaction.merchantName / Transaction.name. Used to
  // detect when monthly payments actually happened (and any excess
  // amount that should be treated as extra principal).
  merchantPatterns String[] @default([])
  // Source provider: "plaid" (default), "snaptrade", or "manual".
  // Determines which *Item relation is populated below.
  provider        String   @default("plaid")
  plaidItemId     String?
  snapTradeItemId String?
  userId          String
  householdId     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  plaidItem     PlaidItem?     @relation(fields: [plaidItemId], references: [id], onDelete: Cascade)
  snapTradeItem SnapTradeItem? @relation(fields: [snapTradeItemId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  household     Household      @relation(fields: [householdId], references: [id], onDelete: Cascade)
  transactions  Transaction[]
  linkedGoals   Goal[]
  extraPayments LoanExtraPayment[]

  @@index([userId])
  @@index([householdId])
}

model SnapTradeItem {
  id                  String   @id @default(cuid())
  // SnapTrade's per-user opaque ID (we use our internal user.id as the
  // SnapTrade userId for 1:1 mapping).
  snapTradeUserId     String
  // Secret returned by SnapTrade at registration. Required for every API
  // call. Encrypted at rest with the same helper used for Plaid tokens.
  userSecretEncrypted String
  // SnapTrade authorization (= connection) ID. Null until the user
  // completes the Connection Portal flow.
  authorizationId     String?  @unique
  brokerageName       String?
  brokerageSlug       String?  // e.g. "ROBINHOOD", "COINBASE", "FIDELITY"
  lastSyncedAt        DateTime?
  userId              String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accounts Account[]

  @@index([userId])
}

model Transaction {
  id                 String   @id @default(cuid())
  plaidTransactionId String?  @unique
  accountId          String
  userId             String
  householdId        String
  categoryId         String?
  amount             Float    // positive = expense, negative = income
  date               DateTime
  name               String
  merchantName       String?
  pending            Boolean  @default(false)
  plaidCategory      String?  // raw Plaid category for reference
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  category  Category? @relation(fields: [categoryId], references: [id])

  @@index([userId])
  @@index([householdId])
  @@index([date])
  @@index([categoryId])
  @@index([accountId])
}

model Category {
  id        String  @id @default(cuid())
  name      String  @unique
  emoji     String
  color     String  // hex color for charts
  isDefault Boolean @default(true)
  sortOrder Int     @default(0)

  transactions    Transaction[]
  budgets         Budget[]
  categoryMappings   CategoryMapping[]
  merchantRules      MerchantCategoryRule[]
  sharingPreferences SharingPreference[]
}

model Budget {
  // Budgets are per-user (privacy: household members must not see each
  // other's budgets). userId is the owner; householdId is kept for
  // cascade-delete when a household goes away. The unique key includes
  // userId so two members can independently budget the same category.
  id           String @id @default(cuid())
  categoryId   String
  householdId  String
  userId       String
  monthlyLimit Float
  month        Int    // 1-12
  year         Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category  Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@unique([categoryId, userId, month, year])
  @@index([householdId, month, year])
  @@index([userId, month, year])
}

model CategoryMapping {
  id            String @id @default(cuid())
  plaidDetailed String @unique // Plaid's detailed personal_finance_category
  categoryId    String

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}

model SharingPreference {
  id                    String   @id @default(cuid())
  userId                String
  categoryId            String
  householdId           String
  sharedWithHousehold   Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category  Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId, householdId])
  @@index([userId, householdId])
}

model HouseholdInvite {
  id          String   @id @default(cuid())
  email       String
  householdId String
  invitedById String
  status      String   @default("pending") // pending | accepted | declined
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  invitedBy User      @relation(fields: [invitedById], references: [id], onDelete: Cascade)

  @@unique([email, householdId])
  @@index([email])
}

model MerchantCategoryRule {
  id          String   @id @default(cuid())
  merchantName String
  categoryId  String
  householdId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category  Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([merchantName, householdId])
  @@index([householdId])
}

model Goal {
  id              String   @id @default(cuid())
  householdId     String
  // Goals are per-user (privacy: household members must not see each
  // other's goals/debts). Required after the 2026-06-04 privacy fix.
  userId          String
  name            String   // "House Mortgage", "Car Loan", "Emergency Fund"
  kind            String   @default("savings")  // "payoff" | "savings" | "custom"
  // Cadence determines how progress is measured. For "one_time", the
  // goal is cumulative — `targetAmount` is the total to reach, progress
  // accumulates without reset (e.g. "Save $20k emergency fund").
  // For "monthly" / "quarterly" / "yearly", `targetAmount` is the
  // per-period target — progress resets at the start of each period
  // (e.g. "Save $500 / month into HYSA").
  cadence         String   @default("one_time")
  targetAmount    Float
  // For payoff goals, this can be left null when linkedAccountId is set —
  // the API derives currentAmount as (targetAmount - account.currentBalance).
  // For savings/custom goals or unlinked payoff goals, this is the manual value.
  currentAmount   Float?
  linkedAccountId String?  // optional Plaid account for auto-sync
  // Case-insensitive substring patterns matched against Transaction.merchantName
  // or Transaction.name. Any matching transaction's absolute amount sums into
  // the goal's current progress (e.g. ["Freedom Mortgage", "Toyota Financial"]).
  merchantPatterns String[] @default([])
  color           String?
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  household     Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  linkedAccount Account?  @relation(fields: [linkedAccountId], references: [id], onDelete: SetNull)
  snapshots     GoalSnapshot[]

  @@index([householdId])
  @@index([userId])
  @@index([linkedAccountId])
}

// One-time extra principal payments the user has made on a manual loan,
// beyond what the merchant-pattern auto-detection picks up. The
// amortization engine subtracts the sum of these (dated after the
// currentBalanceAsOf anchor, if set) from the rolled-forward balance.
model LoanExtraPayment {
  id          String   @id @default(cuid())
  accountId   String
  amount      Float    // dollar amount applied to principal
  date        DateTime // when the payment was made / posted
  notes       String?
  createdAt   DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
}

// Per-period progress snapshot for recurring goals (monthly /
// quarterly / yearly). Written by the cron at the start of each new
// period, capturing what was achieved in the period that just ended.
// Used to render trend sparklines and historical context.
model GoalSnapshot {
  id             String   @id @default(cuid())
  goalId         String
  periodStart    DateTime // first day of the period (e.g. Jan 1)
  periodEnd      DateTime // last instant of the period (e.g. Jan 31 23:59:59)
  achievedAmount Float    // sum of progress during the period
  targetAmount   Float    // per-period target at snapshot time
  createdAt      DateTime @default(now())

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@unique([goalId, periodStart])
  @@index([goalId])
}
