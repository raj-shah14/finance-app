generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Household {
  id        String   @id @default(cuid())
  name      String   @default("My Household")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  accounts     Account[]
  transactions Transaction[]
  budgets            Budget[]
  goals              Goal[]
  sharingPreferences SharingPreference[]
  invites            HouseholdInvite[]
}

model User {
  id          String   @id @default(cuid())
  clerkId     String   @unique
  email       String   @unique
  firstName   String?
  lastName    String?
  imageUrl    String?
  role        String   @default("owner") // owner | member
  householdId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  household    Household?    @relation(fields: [householdId], references: [id])
  plaidItems   PlaidItem[]
  snapTradeItems     SnapTradeItem[]
  accounts     Account[]
  transactions       Transaction[]
  goals              Goal[]
  sharingPreferences SharingPreference[]
  sentInvites        HouseholdInvite[]
}

model PlaidItem {
  id                  String   @id @default(cuid())
  plaidItemId         String   @unique
  accessTokenEncrypted String  // encrypted access token
  institutionId       String?
  institutionName     String?
  cursor              String?  // for transaction sync pagination
  lastSyncedAt        DateTime?
  userId              String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accounts Account[]
}

model Account {
  id              String   @id @default(cuid())
  plaidAccountId  String   @unique
  name            String
  officialName    String?
  // Built-in types: depository, credit, loan, investment.
  // Manual asset types: real_estate, vehicle, other_asset.
  type            String
  subtype         String?  // checking, savings, credit card, primary residence, etc.
  mask            String?  // last 4 digits, or VIN tail for vehicles
  currentBalance  Float?
  availableBalance Float?
  isoCurrencyCode String?  @default("USD")
  // Manual-asset fields (provider="manual"). Optional for aggregator
  // accounts. purchasePrice is the original cost basis; purchaseDate
  // lets us show holding period and compute appreciation.
  purchasePrice   Float?
  purchaseDate    DateTime?
  notes           String?
  // Source provider: "plaid" (default), "snaptrade", or "manual".
  // Determines which *Item relation is populated below.
  provider        String   @default("plaid")
  plaidItemId     String?
  snapTradeItemId String?
  userId          String
  householdId     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  plaidItem     PlaidItem?     @relation(fields: [plaidItemId], references: [id], onDelete: Cascade)
  snapTradeItem SnapTradeItem? @relation(fields: [snapTradeItemId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  household     Household      @relation(fields: [householdId], references: [id], onDelete: Cascade)
  transactions  Transaction[]
  linkedGoals   Goal[]

  @@index([userId])
  @@index([householdId])
}

// SnapTrade is an aggregator we use for brokerage / crypto accounts that
// Plaid doesn't reliably support (Robinhood, Coinbase, Fidelity, etc.).
// One SnapTradeItem represents a single linked institution-connection;
// each connection can expose multiple sub-accounts (e.g. brokerage + IRA).
model SnapTradeItem {
  id                  String   @id @default(cuid())
  // SnapTrade's per-user opaque ID (we use our internal user.id as the
  // SnapTrade userId for 1:1 mapping).
  snapTradeUserId     String
  // Secret returned by SnapTrade at registration. Required for every API
  // call. Encrypted at rest with the same helper used for Plaid tokens.
  userSecretEncrypted String
  // SnapTrade authorization (= connection) ID. Null until the user
  // completes the Connection Portal flow.
  authorizationId     String?  @unique
  brokerageName       String?
  brokerageSlug       String?  // e.g. "ROBINHOOD", "COINBASE", "FIDELITY"
  lastSyncedAt        DateTime?
  userId              String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accounts Account[]

  @@index([userId])
}

model Transaction {
  id                 String   @id @default(cuid())
  plaidTransactionId String?  @unique
  accountId          String
  userId             String
  householdId        String
  categoryId         String?
  amount             Float    // positive = expense, negative = income
  date               DateTime
  name               String
  merchantName       String?
  pending            Boolean  @default(false)
  plaidCategory      String?  // raw Plaid category for reference
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  category  Category? @relation(fields: [categoryId], references: [id])

  @@index([userId])
  @@index([householdId])
  @@index([date])
  @@index([categoryId])
  @@index([accountId])
}

model Category {
  id        String  @id @default(cuid())
  name      String  @unique
  emoji     String
  color     String  // hex color for charts
  isDefault Boolean @default(true)
  sortOrder Int     @default(0)

  transactions    Transaction[]
  budgets         Budget[]
  categoryMappings   CategoryMapping[]
  merchantRules      MerchantCategoryRule[]
  sharingPreferences SharingPreference[]
}

model Budget {
  id           String @id @default(cuid())
  categoryId   String
  householdId  String
  userId       String? // null = household budget, set = personal budget
  monthlyLimit Float
  month        Int    // 1-12
  year         Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category  Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@unique([categoryId, householdId, month, year])
  @@index([householdId, month, year])
  @@index([userId, month, year])
}

model CategoryMapping {
  id            String @id @default(cuid())
  plaidDetailed String @unique // Plaid's detailed personal_finance_category
  categoryId    String

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}

model SharingPreference {
  id                    String   @id @default(cuid())
  userId                String
  categoryId            String
  householdId           String
  sharedWithHousehold   Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category  Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId, householdId])
  @@index([userId, householdId])
}

model HouseholdInvite {
  id          String   @id @default(cuid())
  email       String
  householdId String
  invitedById String
  status      String   @default("pending") // pending | accepted | declined
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  invitedBy User      @relation(fields: [invitedById], references: [id], onDelete: Cascade)

  @@unique([email, householdId])
  @@index([email])
}

model MerchantCategoryRule {
  id          String   @id @default(cuid())
  merchantName String
  categoryId  String
  householdId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category  Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([merchantName, householdId])
  @@index([householdId])
}

model Goal {
  id              String   @id @default(cuid())
  householdId     String
  userId          String?  // null = household goal, set = personal
  name            String   // "House Mortgage", "Car Loan", "Emergency Fund"
  kind            String   @default("savings")  // "payoff" | "savings" | "custom"
  targetAmount    Float
  // For payoff goals, this can be left null when linkedAccountId is set —
  // the API derives currentAmount as (targetAmount - account.currentBalance).
  // For savings/custom goals or unlinked payoff goals, this is the manual value.
  currentAmount   Float?
  linkedAccountId String?  // optional Plaid account for auto-sync
  // Case-insensitive substring patterns matched against Transaction.merchantName
  // or Transaction.name. Any matching transaction's absolute amount sums into
  // the goal's current progress (e.g. ["Freedom Mortgage", "Toyota Financial"]).
  merchantPatterns String[] @default([])
  color           String?
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  household     Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user          User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  linkedAccount Account?  @relation(fields: [linkedAccountId], references: [id], onDelete: SetNull)

  @@index([householdId])
  @@index([userId])
  @@index([linkedAccountId])
}
