# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/finance_app?schema=public"

# Clerk Auth (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Plaid (https://dashboard.plaid.com)
PLAID_CLIENT_ID=xxx
PLAID_SECRET=xxx
PLAID_ENV=sandbox
NEXT_PUBLIC_PLAID_ENV=sandbox

# Encryption key for Plaid tokens (generate: openssl rand -hex 32)
ENCRYPTION_KEY=xxx

# SnapTrade — used for brokerages Plaid doesn't support (Robinhood, Coinbase, Fidelity).
# Sign up at https://snaptrade.com to obtain these.
SNAPTRADE_CLIENT_ID=xxx
SNAPTRADE_CONSUMER_KEY=xxx
CRON_SECRET=... # used to authenticate scheduled cron requests
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Web Push (iOS PWA notifications) ---
# Generate with: npx web-push generate-vapid-keys --json
# Then set all three on Azure App Service Configuration. The
# NEXT_PUBLIC_* variant is bundled to the client so the browser can
# subscribe; the private key stays server-only.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# Contact email returned in VAPID payloads — required by some push services.
VAPID_CONTACT_EMAIL=mailto:admin@thefinancialflows.net

# --- WebAuthn (App Lock with Face ID) ---
# RP (Relying Party) identity used by /api/biometric/*. RP_ID must
# match the bare domain the PWA is served from (no scheme, no port).
WEBAUTHN_RP_ID=thefinancialflows.net
WEBAUTHN_RP_NAME=Financial Flows
WEBAUTHN_ORIGIN=https://thefinancialflows.net
